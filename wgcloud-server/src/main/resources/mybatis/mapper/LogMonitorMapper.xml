<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wgcloud.mapper.LogMonitorMapper">
	<resultMap id="resultMap" type="com.wgcloud.entity.LogMonitor">
		<id column="ID" property="id" jdbcType="CHAR" />
		<result column="HOST_NAME" property="hostname" jdbcType="CHAR" />
		<result column="LOG_FILE_PATH" property="logFilePath" jdbcType="CHAR" />
		<result column="MATCH_SSH_SUCCESS" property="matchSshSuccess" jdbcType="TINYINT" />
		<result column="MATCH_SSH_FAILURE" property="matchSshFailure" jdbcType="TINYINT" />
		<result column="MATCH_SSH_LOGOUT" property="matchSshLogout" jdbcType="TINYINT" />
		<result column="CUSTOM_KEYWORDS" property="customKeywords" jdbcType="CHAR" />
		<result column="ENABLE_ALERT" property="enableAlert" jdbcType="TINYINT" />
		<result column="STATE" property="state" jdbcType="CHAR" />
		<result column="REMARK" property="remark" jdbcType="CHAR" />
		<result column="CREATE_TIME" property="createTime" jdbcType="TIMESTAMP" />
	</resultMap>

	<sql id="tableColumnList">
		ID,HOST_NAME,LOG_FILE_PATH,MATCH_SSH_SUCCESS,MATCH_SSH_FAILURE,MATCH_SSH_LOGOUT,CUSTOM_KEYWORDS,ENABLE_ALERT,STATE,REMARK,CREATE_TIME
	</sql>

	<sql id="queryByParams">
		<if test="hostname != null">
			<![CDATA[ AND HOST_NAME = #{hostname} ]]>
		</if>
		<if test="hostnameList != null and hostnameList.size() > 0">
			AND HOST_NAME IN
			<foreach item="item" index="index" collection="hostnameList" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<if test="state != null">
			<![CDATA[ AND STATE = #{state} ]]>
		</if>
	</sql>

	<select id="selectById" resultMap="resultMap" parameterType="java.lang.String">
		SELECT
		<include refid="tableColumnList" />
		FROM LOG_MONITOR WHERE ID=#{id}
	</select>

	<delete id="deleteByPrimaryKey" parameterType="java.lang.String">
		DELETE FROM LOG_MONITOR WHERE ID = #{id}
	</delete>

	<delete id="deleteById" parameterType="java.lang.String">
		DELETE FROM LOG_MONITOR
		WHERE ID IN
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">#{item}</foreach>
	</delete>

	<delete id="deleteByHostName" parameterType="map">
		DELETE FROM LOG_MONITOR WHERE HOST_NAME = #{hostname}
	</delete>

	<insert id="save" parameterType="com.wgcloud.entity.LogMonitor">
		INSERT INTO LOG_MONITOR
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="id != null">ID,</if>
			<if test="hostname != null">HOST_NAME,</if>
			<if test="logFilePath != null">LOG_FILE_PATH,</if>
			<if test="matchSshSuccess != null">MATCH_SSH_SUCCESS,</if>
			<if test="matchSshFailure != null">MATCH_SSH_FAILURE,</if>
			<if test="matchSshLogout != null">MATCH_SSH_LOGOUT,</if>
			<if test="customKeywords != null">CUSTOM_KEYWORDS,</if>
			<if test="enableAlert != null">ENABLE_ALERT,</if>
			<if test="state != null">STATE,</if>
			<if test="remark != null">REMARK,</if>
			<if test="createTime != null">CREATE_TIME</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="id != null">#{id},</if>
			<if test="hostname != null">#{hostname},</if>
			<if test="logFilePath != null">#{logFilePath},</if>
			<if test="matchSshSuccess != null">#{matchSshSuccess},</if>
			<if test="matchSshFailure != null">#{matchSshFailure},</if>
			<if test="matchSshLogout != null">#{matchSshLogout},</if>
			<if test="customKeywords != null">#{customKeywords},</if>
			<if test="enableAlert != null">#{enableAlert},</if>
			<if test="state != null">#{state},</if>
			<if test="remark != null">#{remark},</if>
			<if test="createTime != null">#{createTime}</if>
		</trim>
	</insert>

	<insert id="insertList" parameterType="java.util.List">
		INSERT INTO LOG_MONITOR (ID,HOST_NAME,LOG_FILE_PATH,MATCH_SSH_SUCCESS,MATCH_SSH_FAILURE,MATCH_SSH_LOGOUT,CUSTOM_KEYWORDS,ENABLE_ALERT,STATE,REMARK,CREATE_TIME)
		VALUES
		<foreach collection="list" item="item" index="index" separator=",">
			(#{item.id},#{item.hostname},#{item.logFilePath},#{item.matchSshSuccess},#{item.matchSshFailure},#{item.matchSshLogout},#{item.customKeywords},#{item.enableAlert},#{item.state},#{item.remark},#{item.createTime})
		</foreach>
	</insert>

	<update id="updateById" parameterType="com.wgcloud.entity.LogMonitor">
		UPDATE LOG_MONITOR
		<set>
			<if test="hostname != null">HOST_NAME = #{hostname},</if>
			<if test="logFilePath != null">LOG_FILE_PATH = #{logFilePath},</if>
			<if test="matchSshSuccess != null">MATCH_SSH_SUCCESS = #{matchSshSuccess},</if>
			<if test="matchSshFailure != null">MATCH_SSH_FAILURE = #{matchSshFailure},</if>
			<if test="matchSshLogout != null">MATCH_SSH_LOGOUT = #{matchSshLogout},</if>
			<if test="customKeywords != null">CUSTOM_KEYWORDS = #{customKeywords},</if>
			<if test="enableAlert != null">ENABLE_ALERT = #{enableAlert},</if>
			<if test="state != null">STATE = #{state},</if>
			<if test="remark != null">REMARK = #{remark},</if>
		</set>
		WHERE ID = #{id}
	</update>

	<select id="selectAllByParams" parameterType="map" resultMap="resultMap">
		SELECT
		<include refid="tableColumnList" />
		FROM LOG_MONITOR t
		<where>
			<include refid="queryByParams" />
		</where>
		ORDER BY CREATE_TIME DESC
	</select>

	<select id="selectByParams" parameterType="map" resultMap="resultMap">
		SELECT
		<include refid="tableColumnList" />
		FROM LOG_MONITOR
		<where>
			<include refid="queryByParams" />
		</where>
		ORDER BY CREATE_TIME DESC
	</select>

	<select id="countByParams" parameterType="map" resultType="java.lang.Integer">
		SELECT count(*) FROM LOG_MONITOR
		<where>
			<include refid="queryByParams" />
		</where>
	</select>

</mapper>
