<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wgcloud.mapper.ContainerInfoMapper">
	<resultMap id="resultMap" type="com.wgcloud.entity.ContainerInfo">
		<id column="ID" property="id" jdbcType="CHAR" />
		<result column="HOSTNAME" property="hostname" jdbcType="CHAR" />
		<result column="CONTAINER_NAME" property="containerName" jdbcType="CHAR" />
		<result column="STATE" property="state" jdbcType="CHAR" />
		<result column="CREATE_TIME" property="createTime" jdbcType="TIMESTAMP" />
	</resultMap>

	<sql id="tableColumnList">
		ID,HOSTNAME,CONTAINER_NAME,STATE,CREATE_TIME
	</sql>

	<sql id="queryByParams">
		<if test="hostname != null">
			<![CDATA[ AND HOSTNAME LIKE CONCAT('%',#{hostname},'%')]]>
		</if>
		<if test="containerName != null">
			<![CDATA[ AND CONTAINER_NAME LIKE CONCAT('%',#{containerName},'%')]]>
		</if>
	</sql>

	<select id="selectById" resultMap="resultMap" parameterType="java.lang.String">
		SELECT <include refid="tableColumnList" /> FROM CONTAINER_INFO WHERE ID=#{id}
	</select>

	<delete id="deleteById" parameterType="java.lang.String">
		DELETE FROM CONTAINER_INFO WHERE ID IN
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">#{item}</foreach>
	</delete>

	<delete id="deleteByHostName" parameterType="map">
		DELETE FROM CONTAINER_INFO WHERE CONTAINER_NAME=#{containerName} AND HOSTNAME=#{hostname}
	</delete>

	<insert id="save" parameterType="com.wgcloud.entity.ContainerInfo">
		INSERT INTO CONTAINER_INFO
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="id != null">ID,</if>
			<if test="hostname != null">HOSTNAME,</if>
			<if test="containerName != null">CONTAINER_NAME,</if>
			<if test="state != null">STATE,</if>
			<if test="createTime != null">CREATE_TIME,</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="id != null">#{id},</if>
			<if test="hostname != null">#{hostname},</if>
			<if test="containerName != null">#{containerName},</if>
			<if test="state != null">#{state},</if>
			<if test="createTime != null">#{createTime},</if>
		</trim>
	</insert>

	<insert id="insertList" parameterType="java.util.List">
		INSERT INTO CONTAINER_INFO (ID,HOSTNAME,CONTAINER_NAME,STATE,CREATE_TIME) VALUES
		<foreach collection="list" item="item" index="index" separator=",">
			(#{item.id},#{item.hostname},#{item.containerName},#{item.state},#{item.createTime})
		</foreach>
	</insert>

	<update id="updateList" parameterType="java.util.List">
		<foreach collection="list" item="item" index="index" separator=";">
			UPDATE CONTAINER_INFO
			<set>
				<if test="item.hostname != null">HOSTNAME = #{item.hostname},</if>
				<if test="item.containerName != null">CONTAINER_NAME = #{item.containerName},</if>
				<if test="item.state != null">STATE = #{item.state},</if>
				<if test="item.createTime != null">CREATE_TIME = #{item.createTime}</if>
			</set>
			WHERE ID = #{item.id}
		</foreach>
	</update>

	<update id="updateById" parameterType="com.wgcloud.entity.ContainerInfo">
		UPDATE CONTAINER_INFO
		<set>
			<if test="hostname != null">HOSTNAME = #{hostname},</if>
			<if test="containerName != null">CONTAINER_NAME = #{containerName},</if>
			<if test="state != null">STATE = #{state},</if>
			<if test="createTime != null">CREATE_TIME = #{createTime}</if>
		</set>
		WHERE ID = #{id}
	</update>

	<select id="countByParams" parameterType="map" resultType="java.lang.Integer">
		SELECT count(*) FROM CONTAINER_INFO t
		<where><include refid="queryByParams" /></where>
	</select>

	<select id="selectAllByParams" parameterType="map" resultMap="resultMap">
		SELECT <include refid="tableColumnList" /> FROM CONTAINER_INFO t
		<where><include refid="queryByParams" /></where>
		ORDER BY CREATE_TIME DESC
	</select>

	<select id="selectByParams" parameterType="map" resultMap="resultMap">
		SELECT <include refid="tableColumnList" /> FROM CONTAINER_INFO
		<where><include refid="queryByParams" /></where>
		ORDER BY CREATE_TIME DESC
	</select>

</mapper>
